{
  "name": "ticketlifeline",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run web:dev --",
    "build": "npm run web:build",
    "web:dev": "vite --config \"Codebase - TicketLifeline Web/vite.config.ts\"",
    "web:build": "tsc --noEmit -p \"Codebase - TicketLifeline Web/tsconfig.json\" && vite build --config \"Codebase - TicketLifeline Web/vite.config.ts\"",
    "web:preview": "vite preview --config \"Codebase - TicketLifeline Web/vite.config.ts\"",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "convex:typecheck": "tsc -p convex/tsconfig.json",
    "test:auth": "node --test tests/emailVerification.test.ts tests/authValidation.test.ts",
    "test:matrix": "node --test tests/visualMatrix.test.ts",
    "test:roles": "node --test tests/roles.test.ts"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.92",
    "convex": "^1.39.1",
    "heic2any": "^0.0.4",
    "jsbarcode": "^3.12.1",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^24.13.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
