<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>TicketLifeline</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>ConvexURL</key>
    <string>$(CONVEX_URL)</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>KeychainAccessGroup</key>
    <string>$(AppIdentifierPrefix)com.ticketlifeline.shared</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSCameraUsageDescription</key>
    <string>TicketLifeline uses the camera to scan and save QR codes and barcodes.</string>
    <key>UIApplicationShortcutItems</key>
    <array>
        <dict>
            <key>UIApplicationShortcutItemIconSymbolName</key>
            <string>photo.badge.plus</string>
            <key>UIApplicationShortcutItemTitle</key>
            <string>Upload Code</string>
            <key>UIApplicationShortcutItemType</key>
            <string>com.ticketlifeline.app.upload-code</string>
        </dict>
        <dict>
            <key>UIApplicationShortcutItemIconSymbolName</key>
            <string>qrcode.viewfinder</string>
            <key>UIApplicationShortcutItemTitle</key>
            <string>Scan Code</string>
            <key>UIApplicationShortcutItemType</key>
            <string>com.ticketlifeline.app.scan-code</string>
        </dict>
    </array>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
</dict>
</plist>
